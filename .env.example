# ValueBot — Variables d'environnement
# Copier ce fichier en .env et adapter les valeurs

# JWT (OBLIGATOIRE en production — generer une cle aleatoire de 64 caracteres)
JWT_SECRET_KEY=

# Google OAuth (optionnel — necessaire pour la connexion Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# PostgreSQL (utilise par Docker Compose)
POSTGRES_USER=valuebot
POSTGRES_PASSWORD=
POSTGRES_DB=valuebot
DATABASE_URL=

# Hermes agent token
HERMES_API_TOKEN=
